# ==================== 应用配置 ====================
APP_NAME=EcoMarket
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# ==================== MySQL 主库 ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root123
MYSQL_DATABASE=ecomarket

# ==================== openGauss 备库 ====================
OPENGUASS_HOST=localhost
OPENGUASS_PORT=5432
OPENGUASS_USER=opengauss_user
OPENGUASS_PASSWORD=og123
OPENGUASS_DATABASE=ecomarket

# ==================== 数据库策略 ====================
# primary: 仅使用MySQL | fallback: MySQL降级openGauss | opengauss_only: 仅openGauss | sqlite: 内存测试用
DB_STRATEGY=sqlite

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# ==================== Qwen3.7-Plus ====================
DASHSCOPE_API_KEY=sk-your-api-key

# ==================== JWT ====================
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== 文件上传 ====================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880
